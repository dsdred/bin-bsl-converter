{
  "name": "bin-bsl-converter",
  "displayName": "BIN-BSL Extractor",
  "description": "Извлечение модулей из Form.bin в .bsl для конфигураций 1С на обычных формах. Извлекает текст модулей для редактирования в VS Code",
  "version": "1.0.2",
  "publisher": "dsdred",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other",
    "Programming Languages"
  ],
  "keywords": [
    "1c",
    "bsl",
    "bin",
    "extractor",
    "1С",
    "обычные формы",
    "form",
    "module",
    "extract"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dsdred/bin-bsl-converter.git"
  },
  "author": "dsdred",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dsdred/bin-bsl-converter/issues"
  },
  "homepage": "https://github.com/dsdred/bin-bsl-converter#readme",
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bin-bsl.extractFromBin",
        "title": "BIN → BSL: Извлечь модуль"
      },
      {
        "command": "bin-bsl.extractFromFolder",
        "title": "BIN → BSL: Извлечь из папки"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .bin",
          "command": "bin-bsl.extractFromBin",
          "group": "bin-bsl"
        },
        {
          "when": "explorerResourceIsFolder",
          "command": "bin-bsl.extractFromFolder",
          "group": "bin-bsl"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0"
  }
}
